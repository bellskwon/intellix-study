# ─── Database ───────────────────────────────────────────────────────────────
# Get this from Railway (add PostgreSQL plugin) or Supabase
DATABASE_URL="postgresql://user:password@localhost:5432/intellix"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a long random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"

# Google OAuth — get from console.cloud.google.com
# Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost:3001/api/auth/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI ──────────────────────────────────────────────────────────────────────
# Get from console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# ─── App URLs ────────────────────────────────────────────────────────────────
# In production: https://intellix.vercel.app
FRONTEND_URL="http://localhost:5173"

# Your backend's own public URL (used to build the Google OAuth callback URL)
# In production: https://intellix-api.railway.app
BACKEND_URL="http://localhost:3001"

# Port for the backend server
PORT=3001
