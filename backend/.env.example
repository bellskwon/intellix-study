# ─── Database ───────────────────────────────────────────────────────────────
# Get this from Railway (add PostgreSQL plugin) or Supabase
DATABASE_URL="postgresql://user:password@localhost:5432/intellix"

# ─── Auth ────────────────────────────────────────────────────────────────────
# Generate a long random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-with-a-long-random-secret"

# Google OAuth — get from console.cloud.google.com
# Create a project → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URIs: http://localhost:3001/api/auth/callback
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ─── AI ──────────────────────────────────────────────────────────────────────
# Get from console.anthropic.com
ANTHROPIC_API_KEY="sk-ant-your-anthropic-api-key"

# ─── App URLs ────────────────────────────────────────────────────────────────
# In production: https://intellix.vercel.app
FRONTEND_URL="http://localhost:5173"

# Your backend's own public URL (used to build the Google OAuth callback URL)
# In production: https://intellix-api.railway.app
BACKEND_URL="http://localhost:3001"

# Port for the backend server
PORT=3001

# ─── Email (Gift Card Orders) ─────────────────────────────────────────────────
# ADMIN_ORDER_EMAIL: the address that receives new gift card order notifications.
# Leave blank if you don't want email notifications (orders are still saved to the DB).
ADMIN_ORDER_EMAIL=""

# ─── Email (Content Moderation) ───────────────────────────────────────────────
# ADMIN_MODERATION_EMAIL: receives alerts when accounts are paused + appeal emails.
# Can be the same address as ADMIN_ORDER_EMAIL.
ADMIN_MODERATION_EMAIL=""

# ADMIN_SECRET: a random string used to authenticate the one-click "Reinstate Account"
# link sent in paused-account emails. Keep this private.
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=""

# ─── Stripe ──────────────────────────────────────────────────────────────────
# Get keys from dashboard.stripe.com → Developers → API keys
# Use sk_test_... / pk_test_... during development
STRIPE_SECRET_KEY=""
# Webhook secret — from stripe listen --forward-to localhost:3001/api/stripe/webhook
# (or from Stripe Dashboard → Webhooks after deploying)
STRIPE_WEBHOOK_SECRET=""

# Price IDs — create products in Stripe Dashboard → Products, copy the price ID (price_...)
STRIPE_PRICE_PRO_MONTHLY=""
STRIPE_PRICE_PRO_YEARLY=""
STRIPE_PRICE_ELITE_MONTHLY=""
STRIPE_PRICE_ELITE_YEARLY=""
STRIPE_PRICE_SCHOOL_MONTHLY=""
STRIPE_PRICE_SCHOOL_YEARLY=""

# ─── SMTP (shared by orders + moderation emails) ─────────────────────────────
# For Gmail: use your Gmail address and an App Password
#   (Google Account → Security → 2-Step Verification → App passwords)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
