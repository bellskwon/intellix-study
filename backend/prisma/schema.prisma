generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  full_name        String?
  display_name     String?
  avatar_emoji     String?
  avatar_color     String?
  avatar_image_url String?
  premium_plan     String    @default("free")
  trial_end_date   DateTime?
  referral_code    String    @unique
  referred_by      String?
  google_id        String?   @unique
  created_date     DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  // ── Content moderation ──────────────────────────────────────────────────
  moderation_warnings Int     @default(0)
  account_paused      Boolean @default(false)

  // ── Payments & Classrooms ────────────────────────────────────────────────
  stripe_customer_id String?
  is_teacher         Boolean @default(false)

  submissions          Submission[]
  study_cards          StudyCard[]
  redemptions          Redemption[]
  calendar_events      CalendarEvent[]
  sent_friendships     Friendship[]    @relation("Requester")
  received_friendships Friendship[]    @relation("Recipient")
  moderation_logs      ModerationLog[]
  owned_classrooms     Classroom[]     @relation("ClassroomOwner")
  class_memberships    ClassMembership[]
}

model Submission {
  id                    String   @id @default(cuid())
  title                 String
  subject               String
  grade_level           String
  type                  String   @default("notes")
  file_url              String?
  notes_text            String?
  status                String   @default("pending_review")
  ai_verification_score Float?
  ai_difficulty_score   Float?
  quiz_score            Float?
  quiz_passed           Boolean  @default(false)
  points_awarded        Int      @default(0)
  rejection_reason      String?
  video_hash            String?
  created_by            String
  created_date          DateTime @default(now())

  user           User           @relation(fields: [created_by], references: [email])
  quiz_questions QuizQuestion[]
}

model QuizQuestion {
  id              String   @id @default(cuid())
  submission_id   String
  question_number Int
  question_text   String
  question_type   String
  options         String[]
  correct_answer  String
  student_answer  String?
  is_correct      Boolean?
  hint            String?
  created_date    DateTime @default(now())

  submission Submission @relation(fields: [submission_id], references: [id], onDelete: Cascade)
}

model StudyCard {
  id               String   @id @default(cuid())
  deck_name        String
  subject          String
  front            String
  back             String
  is_language_card Boolean  @default(false)
  mastery_level    Int      @default(0)
  created_by       String
  created_date     DateTime @default(now())

  user User @relation(fields: [created_by], references: [email])
}

model Redemption {
  id               String   @id @default(cuid())
  reward_id        String
  reward_name      String
  points_spent     Int
  status           String   @default("pending")
  shipping_address String?
  created_by       String
  created_date     DateTime @default(now())

  user User @relation(fields: [created_by], references: [email])
}

model Friendship {
  id              String   @id @default(cuid())
  requester_email String
  recipient_email String
  status          String   @default("pending")
  created_date    DateTime @default(now())

  requester User @relation("Requester", fields: [requester_email], references: [email])
  recipient User @relation("Recipient", fields: [recipient_email], references: [email])
}

model CalendarEvent {
  id           String   @id @default(cuid())
  title        String
  date         String
  type         String   @default("other")
  subject      String?
  notes        String?
  created_by   String
  created_date DateTime @default(now())

  user User @relation(fields: [created_by], references: [email])
}

model Classroom {
  id            String   @id @default(cuid())
  name          String
  subject       String?
  grade_level   String?
  join_code     String   @unique
  teacher_email String
  created_date  DateTime @default(now())

  teacher User              @relation("ClassroomOwner", fields: [teacher_email], references: [email])
  members ClassMembership[]
}

model ClassMembership {
  id            String   @id @default(cuid())
  classroom_id  String
  student_email String
  joined_date   DateTime @default(now())

  classroom Classroom @relation(fields: [classroom_id], references: [id], onDelete: Cascade)
  student   User      @relation(fields: [student_email], references: [email])

  @@unique([classroom_id, student_email])
}

model ModerationLog {
  id             String   @id @default(cuid())
  user_email     String
  content_title  String?
  content_text   String?
  file_url       String?
  subject        String?
  reason         String
  warning_number Int
  appealed       Boolean  @default(false)
  created_date   DateTime @default(now())

  user User @relation(fields: [user_email], references: [email])
}
