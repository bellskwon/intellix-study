{
  "name": "CalendarEvent",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "description": "Event title"
    },
    "date": {
      "type": "string",
      "description": "Date of event (YYYY-MM-DD)"
    },
    "type": {
      "type": "string",
      "enum": [
        "quiz",
        "test",
        "assignment",
        "other"
      ],
      "default": "other"
    },
    "subject": {
      "type": "string"
    },
    "notes": {
      "type": "string"
    }
  },
  "required": [
    "title",
    "date"
  ]
}