{
  "name": "Friendship",
  "type": "object",
  "properties": {
    "requester_email": {
      "type": "string",
      "description": "Email of the person who sent the request"
    },
    "recipient_email": {
      "type": "string",
      "description": "Email of the person receiving the request"
    },
    "status": {
      "type": "string",
      "enum": [
        "pending",
        "accepted",
        "declined"
      ],
      "default": "pending"
    }
  },
  "required": [
    "requester_email",
    "recipient_email"
  ]
}